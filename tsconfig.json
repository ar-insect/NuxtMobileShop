{
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "5.0",
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "nativewind/types"
    ]
  },
  "include": [
    "App.tsx",
    "app.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "extends": "expo/tsconfig.base"
}
